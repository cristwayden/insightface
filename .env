# =============================================================
# .env — InsightFace API Environment Variables
# =============================================================
# Copy this file to .env and adjust according to your environment.
# The .env file must NOT be committed to Git (it is in .gitignore).

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=5005

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_DIR=logs
LOG_FILE=server.log

# --- Paths ---
DATA_DIR=data
RESOURCES_DIR=resources
ANTI_SPOOF_MODELS_DIR=resources/anti_spoof_models
DB_FILE=data/database.json

# --- Face Recognition ---
INSIGHTFACE_MODEL=buffalo_l
DET_SIZE=640
SIMILARITY_THRESHOLD=0.45

# --- Security ---
# API_KEY_HEADER_NAME=X-API-Key          # Header name (default: X-API-Key)
# API_KEY=your_secret_key_here           # Leave empty for dev mode (no auth)
#
# Generate a random key:
#   python -c "import secrets; print(secrets.token_hex(32))"
