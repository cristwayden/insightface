# =============================================================
# .env.example — Template biến môi trường InsightFace API
# =============================================================
# Sao chép file này thành .env và điền giá trị thực tế:
#   cp .env.example .env

# --- Server ---
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Logging ---
LOG_LEVEL=DEBUG
LOG_DIR=logs
LOG_FILE=server.log

# --- Paths ---
DATA_DIR=data
RESOURCES_DIR=resources
ANTI_SPOOF_MODELS_DIR=resources/anti_spoof_models
DB_FILE=data/database.json

# --- Face Recognition ---
INSIGHTFACE_MODEL=buffalo_l
DET_SIZE=640
SIMILARITY_THRESHOLD=0.45

# --- Security (để trống = không bắt xác thực) ---
# API_KEY=your_secret_key_here
